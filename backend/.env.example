PORT=5000
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL 16+ ─────────────────────────────────────────────────────────────
# Local:   postgresql://postgres:password@localhost:5432/simba_supermarket
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Railway:  from your Railway project dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/simba_supermarket

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── Google OAuth ───────────────────────────────────────────────────────────────
# From: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── Google Gemini AI ───────────────────────────────────────────────────────────
# From: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
